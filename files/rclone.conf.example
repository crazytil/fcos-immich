[s3]
# Swap providers by editing this block only. Examples:
#   Cloudflare R2: provider = Cloudflare, endpoint = https://<account>.r2.cloudflarestorage.com
#   Wasabi:        provider = Wasabi,     endpoint = s3.<region>.wasabisys.com, region = <region>
#   Backblaze B2:  provider = Other,      endpoint = s3.<region>.backblazeb2.com
#   AWS S3:        provider = AWS,        region  = <region> (no endpoint)
type = s3
provider = Cloudflare
access_key_id = REPLACE_ACCESS_KEY
secret_access_key = REPLACE_SECRET_KEY
endpoint = https://REPLACE_ACCOUNT_ID.r2.cloudflarestorage.com
directory_markers = true

[storj]
type = s3
provider = Other
endpoint = gateway.storjshare.io
access_key_id = REPLACE_STORJ_ACCESS_KEY
secret_access_key = REPLACE_STORJ_SECRET_KEY
chunk_size = 64Mi
upload_concurrency = 4
